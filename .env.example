# Required: AI provider for validation, reports, advisors, translation, etc.
# Get it from https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Optional but recommended: web search/research provider.
# Nothing is installed on the PC; get a key from https://app.tavily.com
TAVILY_API_KEY=

# Required only for hosted desktop bridge security.
# Generate a long random value. Use the same value as AI_VALIDATOR_DESKTOP_API_KEY
# when building/running the desktop app against the hosted backend.
DESKTOP_AI_SHARED_SECRET=

# Required for persistent desktop token wallet simulation in production.
# Get REST URL and REST token from https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Desktop runtime override, used when building/running Tauri against a hosted backend.
# For local web-only development, these can stay empty/default.
AI_VALIDATOR_DESKTOP_API_URL=https://your-domain.com/api/desktop/ai
AI_VALIDATOR_DESKTOP_WALLET_URL=https://your-domain.com/api/desktop/wallet
AI_VALIDATOR_DESKTOP_API_KEY=
